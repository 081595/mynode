@page
@model TeacherAppointment.Api.Pages.Auth.ConfirmModel
@{
    ViewData["Title"] = "QR 驗證確認";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card card-surface">
                <div class="card-body p-4 text-center">
                    <h1 class="h4 mb-3">QR 驗證確認</h1>
                    <p class="mb-4">請確認是否要進行 QR 驗證。</p>
                    <form id="confirm-qr-form" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="SessionId" />
                        <button class="btn btn-primary btn-lg" type="submit">驗證</button>
                    </form>
                    <div id="confirm-status" class="mt-3"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('confirm-qr-form').addEventListener('submit', async function(e) {
            e.preventDefault();
            const status = document.getElementById('confirm-status');
            status.textContent = '驗證中...';
            const sessionId = document.querySelector('input[name="SessionId"]').value;
            const resp = await fetch(`/api/auth/qr-sessions/${sessionId}/confirm`, { method: 'POST', headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value } });
            if (resp.ok) {
                status.textContent = '驗證成功！可回到桌機完成登入，或直接關閉此頁。';
            } else {
                const err = await resp.json().catch(() => ({}));
                status.textContent = err.message || '驗證失敗，連結已失效或驗證已完成。';
            }
        });
    </script>
}
