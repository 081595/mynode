@page
@model TeacherAppointment.Api.Pages.Admin.AppointmentsModel
@{
    ViewData["Title"] = "聘書維護";
}

<div class="card card-surface mb-4">
    <div class="card-body p-4">
        <h1 class="h5">聘書資料維護</h1>
        <form method="get" class="row g-2 mt-1">
            <div class="col-md-2">
                <input class="form-control" type="number" name="year" value="@Model.Year" min="100" placeholder="年度" />
            </div>
            <div class="col-md-4">
                <input class="form-control" name="employeeNo" value="@Model.EmployeeNo" placeholder="教職員編號" />
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-primary w-100" type="submit">查詢</button>
            </div>
        </form>
        <div id="appointment-admin-status" class="mt-2"></div>
    </div>
</div>

<div class="card card-surface">
    <div class="card-body p-4">
        <div class="table-responsive">
            <table class="table portal-table">
                <thead>
                <tr>
                    <th>文號</th>
                    <th>教職員編號</th>
                    <th>回覆</th>
                    <th>下載</th>
                    <th>備註</th>
                    <th>操作</th>
                </tr>
                </thead>
                <tbody>
                @if (Model.Rows.Count == 0)
                {
                    <tr><td colspan="6" class="text-secondary">目前沒有資料。</td></tr>
                }
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        <td>@row.DocumentNo</td>
                        <td>@row.EmployeeNo</td>
                        <td>@(row.Responded ? "已回覆" : "未回覆")</td>
                        <td>@row.DownloadCount</td>
                        <td>
                            <form method="post" asp-page-handler="UpdateRemark" data-async-form="true" data-status-target="#appointment-admin-status" class="d-flex gap-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="Input.Year" value="@row.Year" />
                                <input type="hidden" name="Input.EmployeeNo" value="@row.EmployeeNo" />
                                <input type="hidden" name="Input.DocYear" value="@row.DocumentYear" />
                                <input type="hidden" name="Input.DocType" value="@row.DocumentType" />
                                <input type="hidden" name="Input.DocSeq" value="@row.DocumentSequence" />
                                <input type="text" class="form-control form-control-sm" name="Input.Remark" value="@row.Remark" placeholder="備註" />
                                <button class="btn btn-sm btn-outline-primary" type="submit">更新</button>
                            </form>
                        </td>
                        <td>
                            <form method="post" asp-page-handler="UploadPdf" enctype="multipart/form-data" data-async-form="true" data-status-target="#appointment-admin-status" class="d-flex gap-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="Upload.Year" value="@row.Year" />
                                <input type="hidden" name="Upload.EmployeeNo" value="@row.EmployeeNo" />
                                <input type="hidden" name="Upload.DocYear" value="@row.DocumentYear" />
                                <input type="hidden" name="Upload.DocType" value="@row.DocumentType" />
                                <input type="hidden" name="Upload.DocSeq" value="@row.DocumentSequence" />
                                <input class="form-control form-control-sm" type="file" name="Upload.PdfFile" accept="application/pdf" />
                                <button class="btn btn-sm btn-outline-secondary" type="submit">上傳</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
