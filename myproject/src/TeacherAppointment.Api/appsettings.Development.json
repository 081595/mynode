    "Audience": "TeacherAppointment.Client.Dev",
    "SigningKey": "dev-only-signing-key-change-me-at-least-32",
    "AccessTokenMinutes": 20,
    "RefreshTokenDays": 7,
    "ClockSkewSeconds": 60
  },
