      "WindowSeconds": 300
    }
  },
  "RoleBasedTestAccountProvisioning": {
    "Enabled": true,
    "EligibleEnvironments": ["Development", "Testing", "Staging"]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
