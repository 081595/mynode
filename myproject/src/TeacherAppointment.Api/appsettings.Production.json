{
  "Sqlite": {
    "ConnectionString": "Data Source=./data/teacher-appointment.prod.db"
  },
  "Jwt": {
    "Issuer": "TeacherAppointment.Api",
    "Audience": "TeacherAppointment.Client",
    "SigningKey": "set-from-secret-store-before-production-deploy",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7,
    "ClockSkewSeconds": 30
  },
  "AuthCookies": {
    "AccessTokenName": "ta_access_token",
    "RefreshTokenName": "ta_refresh_token",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7,
    "SameSite": "Strict",
    "HttpOnly": true,
    "Secure": true
  },
  "RoleBasedTestAccountProvisioning": {
    "Enabled": false,
    "EligibleEnvironments": ["Development", "Testing", "Staging"]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
